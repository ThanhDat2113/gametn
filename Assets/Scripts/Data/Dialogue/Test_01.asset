    - character: {fileID: 0}
      position: 2
      emotion: 3
  - character: {fileID: 11400000, guid: c9c0bb15aa155f04c9e347da2bc948e0, type: 2}
    position: 2
    text: "H\xE3y \u0111i theo anh trai con \u0111\u1EC3 ch\u1EE9ng minh nh\u1EEFng
      g\xEC con \u0111\xE3 h\u1ECDc \u0111\u01B0\u1EE3c \u0111i"
    emotion: 1
    textSpeed: 0
    portraitEffect: 0
    effectDuration: 0
