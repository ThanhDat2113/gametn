  - character: {fileID: 11400000, guid: c9c0bb15aa155f04c9e347da2bc948e0, type: 2}
    position: 2
    text: "V\u1EEBa v\u1EB7n sao,gia t\u1ED9c tay tr\xE1i l\u1EABn gia t\u1ED9c tay
      ph\u1EA3i \u0111\xE3 c\xF3 nh\u1EEFng ng\u01B0\u1EDDi k\u1EBF nhi\u1EC7m "
    emotion: 1
    textSpeed: 0
    portraitEffect: 0
    effectDuration: 0
    backgroundSprite: {fileID: 21300000, guid: 08bd7c046bacb1143878bcce1e8f3d20, type: 3}
    backgroundEffect: 0
