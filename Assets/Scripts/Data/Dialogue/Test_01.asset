  - character: {fileID: 11400000, guid: f847c40c82ee0bf418d1989d93c785fa, type: 2}
    position: 2
    text: "V\xE2ng, ch\xFAng ta hi\u1EC7n \u0111ang ngay tr\u01B0\u1EDBc l\xE2u \u0111\xE0i
      c\u1EE7a nh\xE0 vua"
    emotion: 1
    textSpeed: 0
    portraitEffect: 0
    effectDuration: 0
    backgroundSprite: {fileID: 21300000, guid: 08bd7c046bacb1143878bcce1e8f3d20, type: 3}
