  - character: {fileID: 11400000, guid: c9c0bb15aa155f04c9e347da2bc948e0, type: 2}
    position: 1
    text: "\u0110\xE2y l\xE0 Alex, \u0110\u1EC7 Nh\u1EA5t Ho\xE0ng T\u1EED, l\xE0
      chi\u1EBFn binh m\u1EA1nh nh\u1EA5t ph\u01B0\u01A1ng b\u1EAFc"
    emotion: 1
