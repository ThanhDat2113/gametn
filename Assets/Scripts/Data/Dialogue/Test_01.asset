    position: 2
    text: "Ch\xFAng ta  \u0111\xE3 v\u1EC1 \u0111\u1EBFn ph\u01B0\u01A1ng b\u1EAFc
      r\u1ED3i"
    emotion: 1
    textSpeed: 0
    portraitEffect: 0
