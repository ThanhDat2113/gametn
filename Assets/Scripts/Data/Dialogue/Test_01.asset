      emotion: 3
  - character: {fileID: 11400000, guid: c9c0bb15aa155f04c9e347da2bc948e0, type: 2}
    position: 0
    text: "Ch\xFAng ta \u0111ang \u1EDF \u0111\xE2u"
    emotion: 1
    textSpeed: 0
    portraitEffect: 0
    effectDuration: 0
