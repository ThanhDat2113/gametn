      emotion: 3
  - character: {fileID: 11400000, guid: c9c0bb15aa155f04c9e347da2bc948e0, type: 2}
    position: 2
    text: "Th\u1EBF con \u0111\xE3 h\u1ECDc \u0111\u01B0\u1EE3c g\xEC khi theo h\u1ECDc
      \u1EDF ph\u01B0\u01A1ng t\xE2y r\u1ED3i"
    emotion: 1
    textSpeed: 0
    portraitEffect: 0
    effectDuration: 0
    backgroundSprite: {fileID: 21300000, guid: 08bd7c046bacb1143878bcce1e8f3d20, type: 3}
    backgroundEffect: 0
    backgroundEffectDuration: 0
    voiceClip: {fileID: 0}
    textSound: {fileID: 0}
    otherCharacters:
    - character: {fileID: 0}
      position: 2
      emotion: 3
  - character: {fileID: 11400000, guid: c9c0bb15aa155f04c9e347da2bc948e0, type: 2}
    position: 0
    text: "V\xE2ng, con \u0111\xE3 h\u1ECDc \u0111\u01B0\u1EE3c r\u1EA5t nhi\u1EC1u,
      v\xE0 con mu\u1ED1n ch\u1EE9ng minh \u0111\u1EC3 cho ng\u01B0\u1EDDi th\u1EA5y
      th\u01B0a cha. "
    emotion: 1
    textSpeed: 0
    portraitEffect: 0
    effectDuration: 0
    backgroundSprite: {fileID: 21300000, guid: 08bd7c046bacb1143878bcce1e8f3d20, type: 3}
