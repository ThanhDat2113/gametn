  - character: {fileID: 11400000, guid: c9c0bb15aa155f04c9e347da2bc948e0, type: 2}
    position: 0
    text: "Th\u1EBF th\xEC \u0111i g\u1EB7p Qu\u1ED1c V\u01B0\u01A1ng th\xF4i "
    emotion: 1
    textSpeed: 0
    portraitEffect: 0
