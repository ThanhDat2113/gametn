    - character: {fileID: 0}
      position: 2
      emotion: 3
  - character: {fileID: 11400000, guid: c9c0bb15aa155f04c9e347da2bc948e0, type: 2}
    position: 2
    text: "Th\u1EBF \xE0, hi\u1EC7n anh trai con \u0111ang chu\u1EA9n b\u1ECB c\xF3
      cu\u1ED9c vi\u1EC5n chinh \u1EDF ph\xEDa  c\u1ED5ng th\xE0nh ph\u01B0\u01A1ng
      b\u1EAFc"
    emotion: 1
    textSpeed: 0
    portraitEffect: 0
    effectDuration: 0
    backgroundSprite: {fileID: 21300000, guid: 08bd7c046bacb1143878bcce1e8f3d20, type: 3}
