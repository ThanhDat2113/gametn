  - character: {fileID: 11400000, guid: c9c0bb15aa155f04c9e347da2bc948e0, type: 2}
    position: 2
    text: "V\xE0 h\u1ECD c\u1EA7n nh\u1EEFng kinh nghi\u1EC7m th\u1EF1c chi\u1EBFn,
      h\xE3y \u0111i c\xF9ng v\u1EDBi h\u1ECD v\xE0 l\xE0m quen"
    emotion: 1
    textSpeed: 0
    portraitEffect: 0
    effectDuration: 0
