  - character: {fileID: 11400000, guid: c9c0bb15aa155f04c9e347da2bc948e0, type: 2}
    position: 0
    text: "\u0110\xE3 5 h\u0103m r\u1ED3i, m\u1ECDi th\u1EE9 ch\u1EB3ng thay \u0111\u1ED5i
      m\u1EA5y"
    emotion: 1
    textSpeed: 0
    portraitEffect: 0
