// PRESET 1: CINEMATIC (Dramatic, Horror Movie vibes)
// ═══════════════════════════════════════════════════════════════════════════
/*
Default State:
  Default Ortho Size: 10
  Default Position: (0, 0, 0)
  Camera Height: 5

Zoom Settings:
  Clash Zoom Size: 5          ← VERY CLOSE
  Damage Zoom Size: 6         ← CLOSE
  Zoom In Duration: 0.25      ← FAST
  Zoom Out Duration: 0.6      ← SLOW

Follow Settings:
  Follow Offset: (0, 0, -5)
  Follow Smoothness: 0.1      ← VERY SMOOTH

Shake Settings:
  Shake Intensity: 0.2        ← STRONG
  Shake Duration: 0.25
  Shake Frequency: 20
*/

// ═══════════════════════════════════════════════════════════════════════════
